"use client";
import { useState } from "react";
import Link from "next/link";
import Image from "next/image";
import { Search, X, ArrowRight, ArrowLeft, Mail, Phone } from "lucide-react";

const categories = [
  "DRUGS", "FINANCIAL CRIMES", "MURDER DEFENCE", "NATIONAL SECURITY CRIMES",
  "SEX & HUMAN RIGHTS CRIMES", "TRAFFIC OFFENCES", "VIOLENT CRIMES",
];

// Submenu offence lists — mirroring the original site
const submenuOffences: Record<string, string[]> = {
  DRUGS: [
    "Conspiracy to produce cannabis",
    "Conspiracy to supply Class A drugs",
    "Conspiracy to supply steroids",
    "Cultivation of cannabis",
    "Drug trafficking",
    "Importation of drugs",
    "Importation of steroids",
    "Personal drug possession",
    "Possession with intent to supply",
    "Production of controlled drugs",
    "Others",
    "I am not sure",
  ],
  "FINANCIAL CRIMES": [
    "Credit card fraud", "Benefit fraud", "Money laundering",
    "Tax evasion", "Bribery", "Embezzlement",
    "Insider trading", "Others", "I am not sure",
  ],
  "MURDER DEFENCE": [
    "Murder", "Manslaughter", "Attempted murder",
    "Corporate manslaughter", "Self-defence claims",
    "Diminished responsibility", "Others", "I am not sure",
  ],
  "NATIONAL SECURITY CRIMES": [
    "Terrorism", "Espionage", "Official Secrets Act",
    "Treason", "Sedition", "Others", "I am not sure",
  ],
  "SEX & HUMAN RIGHTS CRIMES": [
    "Sexual assault", "Rape", "Indecent images",
    "Human trafficking", "Modern slavery",
    "Child sexual exploitation", "Others", "I am not sure",
  ],
  "TRAFFIC OFFENCES": [
    "Speeding", "Drink driving", "Drug driving",
    "Dangerous driving", "Death by dangerous driving",
    "Driving without insurance", "Mobile phone offences",
    "Others", "I am not sure",
  ],
  "VIOLENT CRIMES": [
    "Grievous bodily harm", "Actual bodily harm",
    "Common assault", "Assault on a police officer",
    "Robbery", "Kidnapping", "Armed robbery",
    "Others", "I am not sure",
  ],
};

// Title mapping for submenu headers
const submenuTitle: Record<string, string> = {
  DRUGS: "Drug Offence",
  "FINANCIAL CRIMES": "Financial Crime",
  "MURDER DEFENCE": "Murder Defence",
  "NATIONAL SECURITY CRIMES": "National Security Crime",
  "SEX & HUMAN RIGHTS CRIMES": "Sex & Human Rights Crime",
  "TRAFFIC OFFENCES": "Traffic Offence",
  "VIOLENT CRIMES": "Violent Crime",
};

const categorySlug: Record<string, string> = {
  "MURDER DEFENCE": "/criminal-defence-murder",
};
const catHref = (c: string) =>
  categorySlug[c] ||
  "/criminal-defence-" + c.toLowerCase().replace(/\s+/g, "-").replace(/&/g, "").replace(/-+/g, "-");

export default function Header() {
  const [open, setOpen] = useState(false);
  const [submenu, setSubmenu] = useState<string | null>(null);

  const openSubmenu = (cat: string) => setSubmenu(cat);
  const closeSubmenu = () => setSubmenu(null);
  const closeAll = () => {
    setOpen(false);
    setSubmenu(null);
  };

  const offences = submenu ? (submenuOffences[submenu] || []) : [];
  const title = submenu ? (submenuTitle[submenu] || submenu) : "";
  const href = submenu ? catHref(submenu) : "#";

  return (
    <>
      <header className="sticky top-0 z-[999]">
        {/* White top bar */}
        <div className="bg-white">
          <div className="mx-auto flex max-w-[1240px] items-center px-4 py-3 lg:px-8">
            {/* Logo */}
            <Link href="/" className="flex items-center gap-3 flex-shrink-0">
              <Image src="/assets/whiteLogo.svg" alt="Maurice Andrews Solicitors" width={45} height={45} className="h-[38px] w-auto brightness-0 lg:h-[45px]" />
              <div className="hidden sm:block">
                <div className="font-serif text-sm font-bold leading-tight text-primary lg:text-base">Maurice Andrews</div>
                <div className="font-serif text-[10px] tracking-[0.3em] text-primary lg:text-xs">SOLICITORS</div>
              </div>
            </Link>

            {/* Search */}
            <div className="relative ml-auto mr-3 hidden lg:block">
              <input type="text" placeholder="Find my offence" className="w-[260px] rounded-full border border-gray-300 bg-gray-50 py-2 pl-4 pr-10 text-sm text-gray-700 outline-none placeholder:text-gray-400 focus:border-primary" />
              <Search className="absolute right-3.5 top-1/2 h-[18px] w-[18px] -translate-y-1/2 text-gray-400" />
            </div>

            {/* EMAIL US + CALL US NOW buttons */}
            <div className="hidden gap-2 lg:flex">
              <a href="mailto:info@mauriceandrewssolicitors.co.uk" className="flex items-center gap-2 rounded-full border-2 border-primary px-4 py-2 text-xs font-bold text-primary transition-all hover:bg-primary hover:text-white">
                <Mail size={14} />EMAIL US
              </a>
              <a href="tel:01215544900" className="flex items-center gap-2 rounded-full border-2 border-primary px-4 py-2 text-xs font-bold text-primary transition-all hover:bg-primary hover:text-white">
                <Phone size={14} />CALL US NOW
              </a>
            </div>

            {/* Menu button */}
            <button className="ml-3 flex items-center gap-3 lg:ml-4" onClick={() => setOpen(true)} aria-label="Menu">
              <span className="text-sm font-semibold text-primary underline">Menu</span>
              <span className="relative h-10 w-10">
                <span className="absolute left-1/2 top-3 h-0.5 w-[22px] -translate-x-1/2 bg-primary" />
                <span className="absolute left-1/2 top-1/2 h-0.5 w-[22px] -translate-x-1/2 -translate-y-1/2 bg-primary" />
                <span className="absolute bottom-3 left-1/2 h-0.5 w-[22px] -translate-x-1/2 bg-primary" />
              </span>
            </button>
          </div>
        </div>

        {/* Navy navigation strip — 7 direct flat crime links */}
        <nav className="flex overflow-x-auto bg-primary">
          <div className="mx-auto flex max-w-[1240px]">
            {categories.map((c) => (
              <Link key={c} href={catHref(c)} className="whitespace-nowrap px-4 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-white transition-colors hover:bg-white/10 lg:px-[18px]">{c}</Link>
            ))}
            <Link href="/" className="whitespace-nowrap px-4 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-white transition-colors hover:bg-white/10 lg:px-[18px]">Home</Link>
            <Link href="/aboutUs" className="whitespace-nowrap px-4 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-white transition-colors hover:bg-white/10 lg:px-[18px]">About Us</Link>
            <Link href="/ourTeam" className="whitespace-nowrap px-4 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-white transition-colors hover:bg-white/10 lg:px-[18px]">Our Team</Link>
            <Link href="/contactUs" className="whitespace-nowrap px-4 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-white transition-colors hover:bg-white/10 lg:px-[18px]">Contact Us</Link>
            <Link href="/career" className="whitespace-nowrap px-4 py-3 text-[13px] font-bold uppercase tracking-[0.5px] text-white transition-colors hover:bg-white/10 lg:px-[18px]">Career</Link>
          </div>
        </nav>
      </header>

      {/* Mobile slide-out sidebar */}
      {open && (
        <>
          {/* Overlay backdrop */}
          <div className="fixed inset-0 z-[1000] bg-black/50" onClick={closeAll} />

          {/* Main menu OR submenu */}
          <nav className="fixed right-0 top-0 z-[1001] h-full w-[350px] overflow-y-auto bg-nav-bg">
            {submenu ? (
              /* ─── SUBMENU VIEW ─── */
              <div className="relative w-full px-10 py-16 transition-all duration-500">
                {/* Back button */}
                <div className="absolute left-2 top-2 mt-12 cursor-pointer" onClick={closeSubmenu}>
                  <ArrowLeft size={24} className="text-primary" />
                </div>

                {/* Title */}
                <div className="absolute left-0 top-2 -z-10 mt-12 flex w-full justify-center uppercase">
                  <p className="w-2/3 text-center">{title}</p>
                </div>

                {/* Offence list */}
                <div className="mt-12">
                  {offences.map((offence) => (
                    <p key={offence} className="my-5">
                      <Link href={href} className="hover:underline" onClick={closeAll}>{offence}</Link>
                    </p>
                  ))}
                </div>
              </div>
            ) : (
              /* ─── MAIN MENU VIEW ─── */
              <div className="p-10">
                {/* Menu header + close */}
                <div className="mb-5 flex items-center justify-between">
                  <span className="text-lg font-bold text-primary">Menu</span>
                  <button className="text-2xl text-primary" onClick={closeAll}><X /></button>
                </div>

                {/* Home */}
                <ML href="/" onClick={closeAll}>Home</ML>

                {/* 7 defence categories — click opens submenu */}
                {categories.map((c) => (
                  <div
                    key={c}
                    className="flex cursor-pointer items-center justify-between border-b border-black/5 py-2.5 text-base font-medium text-black transition-colors hover:text-primary hover:underline"
                    onClick={() => openSubmenu(c)}
                  >
                    <span>{c}</span>
                    <ArrowRight size={16} />
                  </div>
                ))}

                {/* Other pages */}
                <ML href="/aboutUs" onClick={closeAll}>About Us</ML>
                <ML href="/ourTeam" onClick={closeAll}>Our Team</ML>
                <ML href="/contactUs" onClick={closeAll}>Contact Us</ML>
                <ML href="/career" onClick={closeAll}>Career</ML>
              </div>
            )}
          </nav>
        </>
      )}
    </>
  );
}

function ML({ href, onClick, children }: { href: string; onClick: () => void; children: React.ReactNode }) {
  return (
    <Link href={href} onClick={onClick} className="flex cursor-pointer items-center justify-between border-b border-black/5 py-2.5 text-base font-medium text-black transition-colors hover:text-primary hover:underline">
      {children}
      <ArrowRight size={16} />
    </Link>
  );
}
