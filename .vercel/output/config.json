      "contentType": "text/html; charset=utf-8"
    },
    "index.html": {
      "path": "index",
      "contentType": "text/html; charset=utf-8"
    },
    "ourTeam.html": {
      "path": "ourTeam",
      "contentType": "text/html; charset=utf-8"
