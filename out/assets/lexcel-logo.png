<!--Error 403-->
<!DOCTYPE html>
<html lang="en">

	<head>
		<meta charset="UTF-8">
		<meta http-equiv="X-UA-Compatible"
				content="IE=edge">
		<meta name="viewport"
				content="width=device-width, initial-scale=1.0">
		<title>403 - The Law Society</title>
		<!--Fonts-->
		<style>
			@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600;700&family=Tinos:ital,wght@0,400;0,700;1,400;1,700&display=swap');

		</style>
		<!--Style-->
		<!--Style-->
		<style>
			html,
			body {
				margin: 0;
				padding: 0;
			}

			.header .logo {
				width: 70%;
				margin: 0 auto;
				padding: 10px;
			}

			.container .content .main_icon {
				text-align: center;
			}

			.container {
				height: 80vh;
				font-family: "open sans", "sans-serif";
				display: flex;
				justify-content: center;
				align-items: center;
				flex-direction: column;
				background-color: #FCFAF4;
			}

			.container h1,
			.container h2 {
				font-family: 'Tinos';
				font-style: normal;
				font-weight: 700;
				text-align: center;
				color: #000000;
			}

			.container h1 {
				font-size: 44.79px;
				line-height: 27px;
			}

			.container h2 {
				font-size: 31.1px;
				line-height: 40px;
			}

			.container p {
				font-family: 'Montserrat';
				font-style: normal;
				font-weight: 400;
				font-size: 18px;
				line-height: 32px;
				text-align: center;
				color: #000000;
			}

			.container .content {
				width: 60%;
				margin: 0 auto;
				text-align: center;
			}

			.container .content .content_text {
				text-align: center;
				width: 60%;
				margin: 0 auto;
			}

			.container .content .content_text p {
				font-family: 'Montserrat';
				font-style: normal;
				font-weight: 400;
				font-size: 18px;
				line-height: 32px;
				text-align: center;
				color: #000000;
			}

			.tls_btn_error {
				font-family: 'Montserrat';
				border: 1px solid #004D71;
				background: #004D71;
				outline: none;
				padding: 10px 20px;
				font-size: 15px;
				font-weight: 600;
				color: #fff !important;
				text-transform: uppercase;
				transition: background-color 200ms ease-in;
				margin: 20px 0;
				text-decoration: none;
			}

			.tls_btn_error:hover {
				background-color: #001925;
				cursor: pointer;
				text-decoration: underline;
			}

			a:link {
				color: #574840;
			}

			a:link:hover {
				color: #222;
			}

			footer p {
				font-family: 'Montserrat';
				font-style: normal;
				font-weight: 600;
				font-size: 15px;
				line-height: 27px;
				text-align: center;
				color: #000000;
			}

			/* Extra small devices (phones, 600px and down) */
			@media only screen and (max-width: 600px) {
				.container .content {
					width: 90% !important;
				}

				.container .content .content_text {
					width: 100% !important;
				}

				.container h1 {
					line-height: 40px;
				}

				footer p {
					font-size: 12px;
					line-height: 25px;
				}
			}

			/* Small devices (portrait tablets and large phones, 600px and up) */
			@media only screen and (min-width: 600px) {
				.container .content .content_text {
					width: 100% !important;
				}

				.container h1 {
					line-height: 40px;
				}
			}

		</style>
	</head>

